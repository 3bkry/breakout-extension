{
  "manifest_version": 3,
  "name": "Trading Breakout",
  "version": "1.1",
  "description": "Intercepts TradingView WebSockets and forwards messages. Launch symbol charts from a popup.",
  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.tradingview.com/*",
    "*://symbol-search.tradingview.com/*",
    "https://breakout-alert.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Symbol Launcher"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tradingview.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.tradingview.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "*://*.tradingview.com/*"
      ]
    }
  ]
}